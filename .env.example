# ============================================================
# Peekaboo Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
#
# Tech Stack: React 19 + Vite 7 + Supabase + Capacitor 8
# ============================================================

# ============================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# These credentials enable the app to connect to your Supabase project.
# The anon key is safe to expose in the browser because it only works
# with Row Level Security (RLS) policies that control data access.

# Project URL - Your Supabase project's unique URL
# Format: https://{project-ref}.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key - Safe to expose in the browser
# This key works with Row Level Security (RLS) policies to ensure:
# - Teachers only see classrooms they're assigned to
# - Parents only see photos where their child is tagged
# - All uploads are attributed to the authenticated user
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# OPTIONAL: DEVELOPMENT OVERRIDES
# ============================================================
# These are not currently used but may be helpful for development

# Uncomment to disable telemetry during development
# VITE_DISABLE_TELEMETRY=true

# Uncomment to enable debug mode (verbose console logging)
# VITE_DEBUG=true

# ============================================================
# DEPLOYMENT NOTES
# ============================================================
#
# Local Development:
#   1. Copy this file: cp .env.example .env
#   2. Get credentials from Supabase Dashboard
#   3. Run: npm run dev
#
# Vercel Deployment:
#   Set environment variables in Vercel Dashboard:
#   https://vercel.com/YOUR_PROJECT/settings/environment-variables
#   - VITE_SUPABASE_URL
#   - VITE_SUPABASE_ANON_KEY
#
# Capacitor (iOS/Android):
#   Environment variables are bundled at build time.
#   Run `npm run build && npx cap sync` after changing .env
#
# Security Reminders:
#   - Never commit .env to version control
#   - All VITE_ prefixed vars are exposed to the browser
#   - For server-side secrets, use Supabase Edge Functions
#   - Row Level Security (RLS) protects data, not the anon key
#
# ============================================================
# REQUIRED SUPABASE SETUP
# ============================================================
#
# Before the app will work, ensure your Supabase project has:
#
# 1. Authentication:
#    - Enable "Email" provider with Magic Link
#    - Configure redirect URL: your-app-url/auth/callback
#
# 2. Storage:
#    - Create bucket: "photos" (public: false)
#    - Add storage policies for upload/download
#
# 3. Database Tables (run the migrations):
#    - classrooms
#    - children
#    - photos
#    - photo_tags
#    - classroom_teachers
#    - parent_children
#
# 4. Row Level Security (RLS):
#    - Enable RLS on all tables
#    - Apply the security policies from supabase/migrations/
#
# See docs/SUPABASE_SETUP.md for detailed setup instructions.
# ============================================================
