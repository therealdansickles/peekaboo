# Peekaboo Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# Project URL - Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key - Safe to expose in the browser
# This key works with Row Level Security (RLS) policies
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# NOTES
# ===========================================
# - All env vars prefixed with VITE_ are exposed to the browser
# - Never commit the .env file to version control
# - For production, set these in Vercel environment variables:
#   https://vercel.com/YOUR_PROJECT/settings/environment-variables
